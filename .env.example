# Copy to .env for local dev; add the same three in Vercel > Project > Settings > Environment Variables

# Shared community feed (optional — app runs in local demo mode without these)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Your donation link (Ko-fi, Buy Me a Coffee, Stripe Payment Link, PayPal.me…)
VITE_DONATE_URL=https://ko-fi.com/yourname
